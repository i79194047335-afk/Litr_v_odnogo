# Collector (public trade stream) — no private key needed.
LIGHTER_API_BASE=
LIGHTER_WS_URL=

# 0xArchive — historical backfill only (reference data, see CONTEXT.md).
OXARCHIVE_API_KEY=

# ── Lighter testnet (live track) ──────────────────────────────────────────
# API private key, 80 hex chars, no 0x prefix. NEVER commit the real value.
TESTNET_PRIVATE_KEY=

# Which API key slot the key above belongs to. It MUST match, and the pair
# changes together — that is why both live here rather than in the code.
#
# Do NOT use 0: the Lighter web UI owns that slot (it shows as "0 (Desktop)")
# and re-registers it, which silently kills a bot's key. On 2026-07-17 this
# cost a session — the panel hardcoded 0 and lost the slot to the browser
# twice. Use a slot you created yourself.
#
# To (re)issue: Lighter testnet UI -> API Keys -> Refresh on YOUR index. The
# private key is shown once; copy it before clicking anything else. Verify
# with `python -m src.live.connect_testnet`.
TESTNET_API_KEY_INDEX=

# Your account index, shown in the testnet UI. No default in code: a wrong
# account is a wrong order, and the right value is not guessable.
TESTNET_ACCOUNT_INDEX=
